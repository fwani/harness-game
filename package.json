{
  "name": "harness-game",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "간단한 게임(카드/홀짝/오목/바둑/장기) 멀티 + 기록 시스템",
  "scripts": {
    "dev": "vite",
    "dev:cli": "tsx watch src/infrastructure/cli.ts",
    "start": "tsx src/infrastructure/cli.ts",
    "serve:multi": "tsx src/infrastructure/server/wsServer.ts",
    "build": "tsc -p tsconfig.json",
    "build:ui": "vite build",
    "preview": "vite preview",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "lint": "eslint .",
    "lint:design": "node scripts/check-design-tokens.mjs"
  },
  "dependencies": {
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "ws": "^8.21.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@types/node": "^22.0.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "^4.3.0",
    "eslint": "^9.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.4.0",
    "typescript-eslint": "^8.0.0",
    "vite": "^5.4.0",
    "vitest": "^2.0.0"
  }
}
