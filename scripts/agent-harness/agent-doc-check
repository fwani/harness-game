#!/usr/bin/env sh
# Required-doc + required-section check. Generated by company-agent-harness v0.4.0.
status=0

need_file() {
  if [ -f "$1" ]; then
    printf 'OK   %s\n' "$1"
  else
    printf 'MISS %s\n' "$1"
    status=1
  fi
}

need_section() {
  file="$1"; needle="$2"
  if [ -f "$file" ] && grep -q "$needle" "$file" 2>/dev/null; then
    printf 'OK   %s :: "%s"\n' "$file" "$needle"
  else
    printf 'MISS %s :: "%s"\n' "$file" "$needle"
    status=1
  fi
}

need_file "AGENTS.md"
need_file "ARCHITECTURE.md"
need_file "docs/agent-harness/README.md"
need_file "docs/agent-harness/TESTING.md"
need_file "docs/agent-harness/SECURITY.md"
need_file "docs/agent-harness/OBSERVABILITY.md"
need_file "docs/agent-harness/DOC_GARDENING.md"

need_section "AGENTS.md" "Standard agent working loop"
need_section "AGENTS.md" "Security rules"

if [ "$status" -ne 0 ]; then
  printf '\nDoc check failed: missing files or sections above.\n'
fi
exit $status
