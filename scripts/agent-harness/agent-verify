#!/usr/bin/env sh
# Full verification: lint -> typecheck -> test -> build.
# Generated by company-agent-harness v0.4.0.
# Only commands DETECTED in this repo are baked in; guessed (suggested) commands are
# omitted, so a run never fails on a command this repo doesn't have. To add a check,
# make the command real (e.g. add the npm script) and re-run `agent-harness update`.
status=0
ran=0

run_step() {
  name="$1"; cmd="$2"
  if [ -z "$cmd" ]; then
    printf '\xe2\x80\xa2 %s: not configured (skip)\n' "$name"
    return 0
  fi
  ran=1
  printf '\n=== %s: %s ===\n' "$name" "$cmd"
  if sh -c "$cmd"; then
    printf 'OK   %s\n' "$name"
  else
    printf 'FAIL %s\n' "$name"
    status=1
  fi
}

run_step "lint"        "npm run lint"
run_step "lint:design" "npm run lint:design"
run_step "typecheck"   "npm run typecheck"
run_step "test"      "npm test"
run_step "build"     "npm run build"

if [ "$ran" -eq 0 ]; then
  printf '\nNo checks configured — set commands in .agent-harness.yml, then re-run.\n'
elif [ "$status" -eq 0 ]; then
  printf '\nAll configured checks passed.\n'
else
  printf '\nVerification FAILED. Do not report success.\n'
fi
exit $status
